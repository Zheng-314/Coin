# 鉴泉识珍 - 环境变量配置
# 复制此文件为 .env 并填写你的 API Key

# Flask 密钥（必填，请自定义随机字符串）
SECRET_KEY="your-random-secret-key-here"

# DeepSeek API（大模型对话，必填）
OPENAI_API_KEY="sk-your-deepseek-key"
OPENAI_API_BASE="https://api.deepseek.com/v1"
OPENAI_CHAT_MODEL="deepseek-chat"

# 硅基流动 Embedding API（向量化，必填）
OPENAI_EMBED_API_BASE="https://api.siliconflow.cn/v1"
OPENAI_EMBED_API_KEY="sk-your-siliconflow-key"
OPENAI_EMBED_MODEL="BAAI/bge-large-zh-v1.5"

# 阿里云 Qwen-VL（多模态视觉，可选）
QWEN_API_KEY="sk-your-qwen-key"
QWEN_API_BASE="https://dashscope.aliyuncs.com/compatible-mode/v1"
QWEN_VL_MODEL="qwen-vl-max"

# Tavily 搜索（联网搜索，可选）
TAVILY_API_KEY="tvly-your-tavily-key"

# Neo4j 图数据库（可选，不填则降级到 SQLite）
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password
